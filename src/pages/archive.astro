---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const postsByYear = allPosts.reduce((acc, post) => {
  const year = new Date(post.data.date).getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {} as Record<string, typeof allPosts>);

const sortedYears = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout 
  title="Archive | Quaniq" 
  description="Every article published on Quaniq. Exploring the intersection of quantum mechanics and artificial intelligence."
>
  <div class="relative py-24 min-h-[70vh]">
    <!-- Background element -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 right-1/4 h-[400px] w-[400px] rounded-full bg-[#6366f1]/5 blur-[100px]"></div>
    </div>

    <div class="reading-column relative z-10">
      <header class="mb-20 text-center max-w-2xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">Archive</h1>
        <p class="text-xl text-[#94a3b8] leading-relaxed">
          Every article published on Quaniq.
        </p>
        <p class="text-sm font-semibold text-[#6366f1] mt-6">
          {allPosts.length} articles published
        </p>
      </header>

      <div class="max-w-3xl mx-auto">
        {sortedYears.map(year => (
          <div class="mb-16">
            <h2 class="text-2xl font-bold mb-8 flex items-center gap-4 text-[#f8fafc]">
              {year}
              <div class="h-px bg-[#1e1e2e] flex-1"></div>
            </h2>
            
            <div class="flex flex-col gap-6">
              {postsByYear[year].map(post => {
                const pDate = new Date(post.data.date);
                const formattedDate = pDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
                
                return (
                  <a href={`/posts/${post.slug}`} class="group flex flex-col md:flex-row md:items-center justify-between py-5 border-b border-[#1e1e2e] no-underline hover:bg-[#0f0f1a] -mx-4 px-4 rounded-lg transition-colors">
                    <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-8 mb-3 md:mb-0">
                      <div class="text-sm text-[#94a3b8] w-32 font-mono shrink-0">{formattedDate}</div>
                      <div>
                        <span class="inline-block mb-2 md:mb-1 py-1 px-2 rounded bg-[#1e1e2e] text-[#2dd4bf] text-[10px] font-bold uppercase tracking-widest leading-none">
                          {post.data.topic}
                        </span>
                        <h3 class="text-lg font-bold !mt-0 !mb-0 text-[#f8fafc] group-hover:text-[#6366f1] transition-colors">
                          {post.data.title}
                        </h3>
                      </div>
                    </div>
                    <div class="text-xs text-[#475569] font-medium shrink-0">
                      {post.data.readTime} min read
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
