0---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.jsx';

const benefits = [
  {
    title: "Weekly Deep-Dive Article",
    desc: "Rigorous technical analysis of one quantum or AI concept, complete with derivations and source code where applicable."
  },
  {
    title: "One Curated Research Paper",
    desc: "A hand-picked academic paper from the week, summarized and contextualized for researchers and engineers."
  },
  {
    title: "Pure Signal, No Noise",
    desc: "Zero sponsored content. Zero hype. Only high-fidelity technical writing delivered straight to your inbox."
  }
];
---

<BaseLayout title="The Newsletter | Quaniq" description="Join researchers and engineers who stay at the frontier of quantum computation and intelligent systems.">
  <div class="relative py-24 overflow-hidden">
    <!-- Hero Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute top-0 right-0 h-[500px] w-[500px] rounded-full bg-[#6366f1]/10 blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 h-[500px] w-[500px] rounded-full bg-[#2dd4bf]/5 blur-[120px]"></div>
    </div>

    <div class="reading-column relative z-10">
      <div class="text-center mb-16">
        <span class="inline-block px-3 py-1 rounded bg-[#6366f1]/20 border border-[#6366f1]/30 text-[#6366f1] text-[10px] font-bold uppercase tracking-[0.2em] mb-6">
          The Quaniq Weekly
        </span>
        <h1 class="text-5xl md:text-6xl font-bold mb-6">The Frontier Starts Here</h1>
        <p class="text-xl text-[#94a3b8] leading-relaxed max-w-2xl mx-auto">
          One article. One paper worth reading. Every week. No noise. Join researchers and engineers who read Quaniq.
        </p>
      </div>

      <div class="max-w-xl mx-auto p-12 rounded-3xl bg-[#0f0f1a] border border-[#1e1e2e] shadow-2xl mb-24">
        <NewsletterForm client:load />
        <p class="text-xs text-[#475569] mt-6 text-center italic">
          No spam. Unsubscribe anytime with one click.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 border-t border-[#1e1e2e] pt-24">
        {benefits.map((benefit) => (
          <div>
            <div class="h-10 w-10 rounded bg-[#6366f1]/10 flex items-center justify-center mb-6">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <h3 class="text-lg font-bold mb-3">{benefit.title}</h3>
            <p class="text-sm text-[#94a3b8] leading-relaxed">
              {benefit.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
