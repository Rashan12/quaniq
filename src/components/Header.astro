---
const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Topics', href: '/topics' },
  { name: 'Newsletter', href: '/newsletter' },
  { name: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full border-b border-[#1e1e2e] bg-[#0a0a0f]/80 backdrop-blur-lg">
  <div class="reading-column flex h-20 items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 no-underline">
      <img src="/images/quaniq-logo.svg" alt="Quaniq Logo" class="h-8 w-8" />
      <span class="text-xl font-bold tracking-tighter text-[#f8fafc]">QUANIQ</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class:list={[
            "relative text-sm font-medium no-underline transition-colors hover:text-[#6366f1]",
            currentPath === link.href ? "text-[#f8fafc]" : "text-[#94a3b8]"
          ]}
        >
          {link.name}
          {currentPath === link.href && (
            <span class="absolute -bottom-[29px] left-0 h-[2px] w-full bg-[#6366f1]" />
          )}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <button id="search-trigger" class="p-2 text-[#94a3b8] hover:text-[#f8fafc] transition-colors" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <a href="/newsletter" class="hidden sm:inline-flex rounded-md bg-[#6366f1] px-4 py-2 text-xs font-semibold text-white no-underline hover:bg-[#4f46e5] transition-colors">
        Subscribe
      </a>
      <!-- Mobile Menu Toggle -->
      <button id="mobile-menu-toggle" class="md:hidden p-2 text-[#94a3b8]" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Sidebar -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-[#0a0a0f] transform translate-x-full transition-transform duration-300 md:hidden">
  <div class="flex flex-col p-8">
    <div class="flex items-center justify-between mb-12">
      <span class="text-xl font-bold tracking-tighter text-[#f8fafc]">QUANIQ</span>
      <button id="mobile-menu-close" class="p-2 text-[#94a3b8]">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <nav class="flex flex-col gap-6">
      {navLinks.map((link) => (
        <a href={link.href} class="text-lg font-medium text-[#94a3b8] no-underline hover:text-[#f8fafc]">
          {link.name}
        </a>
      ))}
      <a href="/newsletter" class="mt-4 rounded-md bg-[#6366f1] px-6 py-3 text-center text-sm font-semibold text-white no-underline">
        Subscribe
      </a>
    </nav>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const close = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.remove('translate-x-full');
  });

  close?.addEventListener('click', () => {
    menu?.classList.add('translate-x-full');
  });
</script>
