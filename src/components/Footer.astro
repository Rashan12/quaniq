---
import NewsletterForm from './NewsletterForm.jsx';
const topics = [
  { name: 'Quantum ML', href: '/topics/quantum-ml' },
  { name: 'Quantum Algorithms', href: '/topics/algorithms' },
  { name: 'Foundations', href: '/topics/foundations' },
  { name: 'Industry', href: '/topics/industry' },
];
---

<footer class="mt-20 border-t border-[#1e1e2e] bg-[#0a0a0f] py-16">
  <div class="reading-column grid grid-cols-1 gap-12 md:grid-cols-3">
    <!-- Info -->
    <div>
      <div class="flex items-center gap-3 mb-4">
        <img src="/images/quaniq-logo.svg" alt="Quaniq Logo" class="h-6 w-6" />
        <span class="text-lg font-bold tracking-tighter text-[#f8fafc]">QUANIQ</span>
      </div>
      <p class="text-sm text-[#94a3b8] leading-relaxed mb-4">
        Exploring the frontier of quantum computation and intelligent systems.
      </p>
      <p class="text-xs text-[#475569]">
        A publication by <span class="text-[#94a3b8]">Intellit</span>
      </p>
    </div>

    <!-- Topics -->
    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider text-[#f8fafc] mb-6 !mt-0">Topics</h4>
      <ul class="flex flex-col gap-3 list-none p-0 m-0">
        {topics.map((topic) => (
          <li>
            <a href={topic.href} class="text-sm text-[#94a3b8] no-underline hover:text-[#6366f1] transition-colors">
              {topic.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Newsletter -->
    <div class="min-w-0">
      <h4 class="text-sm font-semibold uppercase tracking-wider text-[#f8fafc] mb-6 !mt-0">Newsletter</h4>
      <p class="text-sm text-[#94a3b8] mb-4">Stay ahead with quantum insights.</p>
      <div class="w-full">
        <NewsletterForm client:load variant="footer" />
      </div>
    </div>
  </div>

  <div class="reading-column mt-16 pt-8 border-t border-[#1e1e2e] flex flex-col sm:flex-row justify-between items-center gap-4">
    <p class="text-xs text-[#475569]">
      &copy; {new Date().getFullYear()} Quaniq. All rights reserved.
    </p>
    <div class="flex gap-6">
      <a href="/privacy" class="text-xs text-[#475569] no-underline hover:text-[#94a3b8]">Privacy Policy</a>
      <span class="text-xs text-[#475569]">Built with Astro</span>
    </div>
  </div>
</footer>
