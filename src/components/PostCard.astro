---
interface Props {
  title: string;
  excerpt: string;
  topic: string;
  date: string;
  readTime: string;
  image: string;
  href: string;
  author: { name: string };
}

const { title, excerpt, topic, date, readTime, image, href, author } = Astro.props;
---

<article class="group relative rounded-xl border border-[#1e1e2e] bg-[#0f0f1a] overflow-hidden transition-all hover:border-[#6366f1]/50 hover:-translate-y-1 shadow-lg">
  <a href={href} class="block no-underline">
    <div class="aspect-video w-full overflow-hidden bg-[#1e1e2e]">
      <img 
        src={image} 
        alt={`Thumbnail for ${title}`} 
        class="h-full w-full object-cover grayscale-[0.4] group-hover:grayscale-0 transition-all duration-500 scale-100 group-hover:scale-105" 
        loading="lazy"
        width="800"
        height="450"
        style="width:100%; height:200px; object-fit:cover;"
        onerror="this.src='/images/posts/placeholder-hero.png'"
      />
    </div>
    <div class="p-6">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[10px] font-bold text-[#2dd4bf] uppercase tracking-widest">{topic}</span>
        <span class="text-[10px] text-[#475569]">{readTime} min read</span>
      </div>
      <h3 class="text-xl font-bold text-[#f8fafc] !mt-0 mb-3 group-hover:text-[#6366f1] transition-colors line-clamp-2 leading-tight">
        {title}
      </h3>
      <p class="text-sm text-[#94a3b8] mb-6 line-clamp-2 leading-relaxed">
        {excerpt}
      </p>
      <div class="flex items-center justify-between pt-4 border-t border-[#1e1e2e]">
        <div class="text-[10px] font-semibold text-[#475569]">{author.name}</div>
        <div class="text-[10px] text-[#475569] font-mono">{date}</div>
      </div>
    </div>
  </a>
</article>
