---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import NewsletterForm from '../components/NewsletterForm.jsx';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: string;
  topic: string;
  author: {
    name: string;
    role: string;
    image?: string;
  };
  readTime: string;
  heroImage?: string;
  tags?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const { 
  title, 
  description, 
  date, 
  topic, 
  author, 
  readTime, 
  heroImage = "/images/posts/default-hero.jpg",
  tags = [],
  headings = []
} = Astro.props;

const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);
const siteUrl = "https://quaniq.netlify.app";
const formattedDate = new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const allPosts = await getCollection('posts');
const currentPath = Astro.url.pathname;
const currentSlug = currentPath.split('/').filter(Boolean).pop();

let pool = allPosts.filter(p => p.slug !== currentSlug);
pool.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const sameTopicPosts = pool.filter(p => p.data.topic === topic);
const otherPosts = pool.filter(p => p.data.topic !== topic);

const relatedPosts = [...sameTopicPosts, ...otherPosts].slice(0, 3);

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": `${siteUrl}${heroImage}`,
  "datePublished": date,
  "author": {
    "@type": "Person",
    "name": author.name
  },
  "publisher": {
    "@type": "Organization",
    "name": "Quaniq",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/images/quaniq-logo.svg`
    }
  }
};
---

<BaseLayout 
  title={`${title} | Quaniq`} 
  description={description} 
  ogImage={heroImage} 
  isArticle={true}
>
  <!-- Schema.org -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  <article class="relative pt-12 pb-24">
    <!-- Post Header -->
    <header class="reading-column mb-12">
      <span class="inline-block py-1 px-2 rounded bg-[#0f0f1a] text-[#2dd4bf] text-xs font-bold uppercase tracking-widest mb-4">
        {topic}
      </span>
      <h1 class="text-4xl md:text-5xl font-bold !mt-0 mb-4 leading-tight">{title}</h1>
      <p class="text-xl text-[#94a3b8] mb-8 leading-relaxed">{description}</p>
      
      <div class="flex items-center gap-4 border-y border-[#1e1e2e] py-6 mb-8">
        <div style="display: flex; align-items: center; gap: 12px;">
          <div class="h-10 w-10 shrink-0">
            <img 
              src="/images/rashan.jpg"
              alt="Rashan Dissanayaka"
              width="48"
              height="48"
              style="width:48px; height:48px; border-radius:50%; object-fit:cover; object-position:top center;"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div style="display:none;" class="w-full h-full bg-[#1e1e2e] font-bold text-[#f8fafc] items-center justify-center text-sm border border-[#2dd4bf]/20 rounded-full">RD</div>
          </div>
          <div>
            <div style="font-weight: 600; color: #f8fafc;">
              Rashan Dissanayaka
            </div>
            <div style="font-size: 0.85rem; color: #94a3b8;">
              Data Science Professional & Quantum AI Researcher · Founder/CEO, Intellit
            </div>
          </div>
        </div>
        <div class="ml-auto flex items-center gap-4 text-xs text-[#475569]">
          <span>{formattedDate}</span>
          <span>•</span>
          <span>{readTime} min read</span>
        </div>
      </div>

      {heroImage && (
        <div class="w-full aspect-video rounded-xl overflow-hidden bg-[#0f0f1a] border border-[#1e1e2e]">
          <img 
            src={heroImage} 
            alt={`Hero analysis visualization for: ${title}`} 
            class="w-full h-full object-cover" 
            width="1200"
            height="675"
            onerror="this.src='/images/posts/placeholder-hero.png'"
          />
        </div>
      )}
    </header>

    <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-12">
      <!-- Sidebar TOC -->
      <aside class="hidden lg:block">
        <div class="sticky top-32">
          <h4 class="text-xs font-bold uppercase tracking-widest text-[#475569] mb-4 !mt-0">Table of Contents</h4>
          <nav>
            <ul class="list-none p-0 m-0 space-y-3">
              {filteredHeadings.map((h) => (
                <li class={`pl-${(h.depth - 2) * 4}`}>
                  <a 
                    href={`#${h.slug}`} 
                    class="text-sm text-[#94a3b8] no-underline hover:text-[#6366f1] transition-colors line-clamp-2"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="prose">
        <slot />

        <!-- Post Footer Actions -->
        <hr />
        
        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-12">
          {tags.map(tag => (
            <span class="px-3 py-1 bg-[#0f0f1a] border border-[#1e1e2e] rounded text-xs text-[#94a3b8]">
              #{tag}
            </span>
          ))}
        </div>

        <!-- Author Card -->
        <div class="p-8 rounded-xl bg-[#0f0f1a] border border-[#1e1e2e] flex items-start gap-6 mb-12">
          <div class="h-16 w-16 shrink-0">
            <img 
              src="/images/rashan.jpg"
              alt="Rashan Dissanayaka"
              width="80"
              height="80"
              style="width:80px; height:80px; border-radius:50%; object-fit:cover; object-position:top center;"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div style="display:none;" class="w-full h-full bg-[#1e1e2e] font-bold text-[#f8fafc] items-center justify-center text-xl border border-[#2dd4bf]/20 rounded-full">RD</div>
          </div>
          <div>
            <h4 class="!mt-0 mb-2">{author.name}</h4>
            <p class="text-sm text-[#94a3b8] mb-0 leading-relaxed">
              Rashan is a Data Science Professional and Quantum AI Researcher, and the Founder & CEO of Intellit — an AI automation agency building intelligent systems across fintech, banking, and enterprise sectors.
            </p>
          </div>
        </div>

        <!-- Newsletter Promo -->
        <div class="p-10 rounded-xl bg-[#6366f1] text-white relative overflow-hidden">
          <div class="relative z-10 flex flex-col items-center text-center">
            <h3 class="text-2xl font-bold text-white !mt-0 mb-2">The Quantum Intelligence Digest</h3>
            <p class="text-indigo-100 mb-6 max-w-md">Join researchers and engineers who read Quaniq.</p>
            <NewsletterForm client:load variant="post" />
          </div>
          <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Posts Placeholder -->
  <section class="bg-[#0f0f1a] py-20 border-y border-[#1e1e2e]">
    <div class="reading-column">
      <h3 class="!mt-0 mb-8 font-bold">Related Exploration</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {relatedPosts.map(p => {
          const pData = p.data;
          const pHero = pData.heroImage || '/images/posts/placeholder-hero.png';
          return (
            <a href={`/posts/${p.slug}`} class="block rounded-lg bg-[#0a0a0f] border border-[#1e1e2e] overflow-hidden hover:border-[#6366f1] transition-colors group no-underline">
              <div class="aspect-video bg-[#1e1e2e] overflow-hidden">
                <img 
                  src={pHero} 
                  alt={pData.title} 
                  class="w-full h-full object-cover grayscale-[0.4] group-hover:grayscale-0 transition-all duration-500 scale-100 group-hover:scale-105"
                  onerror="this.src='/images/posts/placeholder-hero.png'"
                />
              </div>
              <div class="p-4">
                <div class="text-[10px] text-[#2dd4bf] font-bold uppercase mb-2">{pData.topic}</div>
                <h4 class="text-sm font-bold !mt-0 !mb-0 text-[#f8fafc] group-hover:text-[#6366f1] transition-colors">{pData.title}</h4>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
